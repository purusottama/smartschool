{
    "info": {
        "name": "Smart School \u2014 Multi-School (2 schools, all roles)",
        "description": "Multi-tenant demo. Pick a school via {{school_id}}/{{school_code}} then run a login.\n\nAuth paths:\n- Student/Parent: POST {{base_url}}/api/auth/login (returns token -> auto-stored in {{access_token}}).\n- Staff (Admin/Teacher/Accountant): POST {{base_url}}/customapi/login/staffLogin (session-based).\n\nSwitch schools by changing {{school_id}} (1=Greenwood, 2=Sunrise) and the matching credentials in the environment.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "0. Schools",
            "item": [
                {
                    "name": "Schools :: list",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "urlencoded",
                            "urlencoded": []
                        },
                        "url": {
                            "raw": "{{base_url}}/customapi/schools/list",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "customapi",
                                "schools",
                                "list"
                            ]
                        },
                        "description": "Public list of active schools for the app login-screen picker."
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "var j = pm.response.json();",
                                    "pm.test('has schools', function(){ pm.expect(j.status).to.eql(true); });"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "1. Login \u2014 Student & Parent (token)",
            "item": [
                {
                    "name": "Student login (uses {{school_id}})",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Client-Service",
                                "value": "smartschool"
                            },
                            {
                                "key": "Auth-Key",
                                "value": "schoolAdmin@"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"{{student_user}}\",\n    \"password\": \"{{student_pass}}\",\n    \"deviceToken\": \"postman-device\",\n    \"school_id\": \"{{school_id}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        },
                        "description": "Scoped to {{school_id}}. Auto-stores {{access_token}}, {{user_id}}, {{student_id}}."
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "var j = pm.response.json();",
                                    "if (j && j.token) { pm.environment.set('access_token', j.token); console.log('token stored'); }",
                                    "if (j && j.id) { pm.environment.set('user_id', j.id); }",
                                    "if (j && j.record && j.record.student_id) { pm.environment.set('student_id', j.record.student_id); }",
                                    "pm.test('login success', function(){ pm.expect(String(j.status)).to.eql('1'); });"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Parent login (uses {{school_id}})",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
