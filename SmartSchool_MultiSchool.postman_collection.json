                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "var j = pm.response.json();",
                                    "pm.test('Student login', function(){ pm.expect(String(j.status)).to.eql('1'); });",
                                    "if (j.token) pm.environment.set('access_token', j.token);",
                                    "if (j.id) pm.environment.set('user_id', j.id);",
                                    "if (j.record && j.record.student_id) pm.environment.set('student_id', j.record.student_id);",
